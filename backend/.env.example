# Database Connection
# For Railway: copy the DATABASE_URL from your Railway service dashboard
# For local development: use your local PostgreSQL connection string
DATABASE_URL="postgresql://username:password@localhost:5432/wagh_rental_db"

# Gmail Integration (optional — for auto-scanning emails)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3005/api/gmail/callback

# Claude Chat (optional — for AI chat feature)
ANTHROPIC_API_KEY=

# Frontend URL (for OAuth redirect in production)
FRONTEND_URL=http://localhost:5173
